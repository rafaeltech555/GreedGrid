{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GreedGrid",
  "version": "0.1.0",
  "identifier": "com.rafaeltech555.greedgrid",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GreedGrid",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; frame-src *"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Rafael (rafaeltech555)",
    "shortDescription": "Screen-splitting monitoring dashboard",
    "longDescription": "GreedGrid splits one window into a resizable, mergeable grid of panels — terminals, file browsers, web dashboards, and system monitors — saved as named workspaces.",
    "category": "Utility",
    "copyright": "© 2026 Rafael",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
